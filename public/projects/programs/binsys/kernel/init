#!/bin/sh
# ════════════════════════════════════════════════════════════════════════════
#  /init — Hardened AIOS initramfs early userspace
#
#  HARDENING CHANGES
#  ─────────────────
#  • All cmdline values are validated (regex) before use — prevents path
#    traversal, injection, and malformed size strings.
#  • resolve_dev canonicalises with readlink -f and verifies the result is
#    actually under /dev and is a block device (symlink attack resistance).
#  • wait_for_dev uses a bounded poll; individual findfs/mount ops are wrapped
#    with a timeout helper to prevent hanging on damaged media.
#  • Mount options hardened: nodev,nosuid,noexec on media; nodev,nosuid on upper.
#  • squashfs magic verified before mount (reduces attack surface from forged fs).
#  • Cleanup tracking: all mounts are recorded; on any failure the emergency
#    path unmounts in reverse order to leave the system in a known state.
#  • Emergency shell now logs extensively to /dev/kmsg and pauses 5 s to allow
#    physical console capture; optional aios.emergency_reboot=N reboots after N s.
#  • rd.break is preserved but emits a loud warning.
#  • switch_root target is validated (must exist, must be executable, must not
#    be a symlink outside the newroot).
# ════════════════════════════════════════════════════════════════════════════

set -u

# ─── Constants ───────────────────────────────────────────────────────────────
NEWROOT="/newroot"
LOWER="/mnt/lower"
UPPER_BASE="/mnt/rw"
MEDIA="/mnt/media"
SQUASH_DEFAULT_FILE="aios.squashfs"
DEFAULT_LABEL="AIOS"
PROBE_TIMEOUT=15

# Track mounts for cleanup (space-separated list, LIFO order)
CLEANUP_MOUNTS=""

# ─── Output helpers ──────────────────────────────────────────────────────────
_kmsg() {
  if [ -w /dev/kmsg ]; then
    printf '<6>aios-init: %s\n' "$*" > /dev/kmsg 2>/dev/null || true
  fi
}
log()  { printf '\033[1;32m[aios-init]\033[0m %s\n' "$*"; _kmsg "$*"; }
warn() { printf '\033[1;33m[aios-init]\033[0m %s\n' "$*"; _kmsg "WARN: $*"; }
err()  { printf '\033[1;31m[aios-init]\033[0m %s\n' "$*" >&2; _kmsg "ERR: $*"; }

# ─── Cleanup ─────────────────────────────────────────────────────────────────
record_mount() { CLEANUP_MOUNTS="$1 $CLEANUP_MOUNTS"; }
cleanup_mounts() {
  for m in $CLEANUP_MOUNTS; do
    umount -r "$m" 2>/dev/null || umount -l "$m" 2>/dev/null || true
  done
  CLEANUP_MOUNTS=""
}

# ─── Emergency shell / panic ───────────────────────────────────────────────────
emergency() {
  err "$1"
  cleanup_mounts
  err "Dropping to emergency shell. System did NOT boot."
  err "Diagnostics: cat /proc/cmdline; blkid; dmesg | tail; ls /dev"
  _kmsg "EMERGENCY: $1"

  # Ensure pseudo-filesystems exist for the shell
  [ -d /proc ] && mountpoint -q /proc 2>/dev/null || mount -t proc proc /proc 2>/dev/null || true
  [ -d /sys  ] && mountpoint -q /sys  2>/dev/null || mount -t sysfs sysfs /sys 2>/dev/null || true
  mountpoint -q /dev 2>/dev/null || mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
  mkdir -p /dev/pts && mount -t devpts devpts /dev/pts 2>/dev/null || true

  # Optional auto-reboot to avoid hanging forever on headless systems
  REBOOT_AFTER=""
  for tok in $(cat /proc/cmdline 2>/dev/null); do
    case "$tok" in aios.emergency_reboot=*) REBOOT_AFTER="${tok#*=}" ;; esac
  done
  if [ -n "$REBOOT_AFTER" ]; then
    warn "rebooting in ${REBOOT_AFTER}s (aios.emergency_reboot)"
    ( sleep "$REBOOT_AFTER" && reboot -f ) &
  fi

  # Pause briefly so console messages are visible before the shell prompt
  sleep 5
  exec /bin/sh
}

trap 'emergency "unexpected error in /init (trap EXIT)"' EXIT

# ─── Phase 1: pseudo-filesystems ─────────────────────────────────────────────
mkdir -p /proc /sys /dev /run "$NEWROOT" "$LOWER" "$UPPER_BASE" "$MEDIA"
mount -t proc     proc     /proc  2>/dev/null || emergency "cannot mount /proc"
mount -t sysfs    sysfs    /sys   2>/dev/null || emergency "cannot mount /sys"
mountpoint -q /dev 2>/dev/null || mount -t devtmpfs devtmpfs /dev 2>/dev/null \
  || emergency "cannot mount /dev (is CONFIG_DEVTMPFS_MOUNT=y?)"
mount -t tmpfs    tmpfs    /run   2>/dev/null || true
mkdir -p /dev/pts && mount -t devpts devpts /dev/pts 2>/dev/null || true

# ─── Phase 2: parse /proc/cmdline ────────────────────────────────────────────
CMDLINE="$(cat /proc/cmdline 2>/dev/null || echo '')"

get_param() {
  for tok in $CMDLINE; do
    case "$tok" in "$1"=*) printf '%s' "${tok#*=}"; return 0 ;; esac
  done
  return 1
}
has_flag() {
  for tok in $CMDLINE; do [ "$tok" = "$1" ] && return 0; done
  return 1
}

has_flag rd.debug && set -x

SQUASH_SPEC="$(get_param aios.squash || true)"
PERSIST_SPEC="$(get_param aios.persist || true)"
UPPER_SIZE="$(get_param aios.upper_size || echo '50%')"
ROOT_LABEL="$(get_param aios.root_label || echo "$DEFAULT_LABEL")"

# ─── Input validation ────────────────────────────────────────────────────────
validate_size() {
  case "$1" in
    [0-9]*%|[0-9]*[KkMmGgTt]|[0-9]*) return 0 ;;
    *) emergency "invalid aios.upper_size: '$1' (expected e.g. 50%, 2G, 512M)" ;;
  esac
}
validate_label() {
  case "$1" in
    [a-zA-Z0-9_-]*) return 0 ;;
    *) emergency "invalid aios.root_label: '$1' (expected alphanumeric, _, -)" ;;
  esac
}
validate_devspec() {
  # Reject specs containing .. or shell metacharacters
  case "$1" in
    *..*|*[`;&|<>$\\]*) emergency "invalid device spec: '$1' (contains forbidden characters)" ;;
  esac
}

validate_size "$UPPER_SIZE"
validate_label "$ROOT_LABEL"
[ -n "$SQUASH_SPEC" ] && validate_devspec "$SQUASH_SPEC"
[ -n "$PERSIST_SPEC" ] && validate_devspec "$PERSIST_SPEC"

log "cmdline: squash='${SQUASH_SPEC:-<auto>}' persist='${PERSIST_SPEC:-<tmpfs>}' upper_size='${UPPER_SIZE}' label='${ROOT_LABEL}'"

# ─── Timeout wrapper (busybox timeout or manual) ─────────────────────────────
with_timeout() {
  local sec="$1"; shift
  if command -v timeout >/dev/null 2>&1; then
    timeout "$sec" "$@"
  else
    "$@" &
    local pid=$!
    ( sleep "$sec"; kill "$pid" 2>/dev/null ) &
    wait "$pid" 2>/dev/null
  fi
}

# ─── resolve_one (hardened) ───────────────────────────────────────────────────
resolve_one() {
  local spec="$1" dev=""
  case "$spec" in
    LABEL=*)    dev="$(with_timeout 5 findfs "LABEL=${spec#LABEL=}" 2>/dev/null || true)" ;;
    UUID=*)     dev="$(with_timeout 5 findfs "UUID=${spec#UUID=}" 2>/dev/null || true)" ;;
    PARTUUID=*) dev="$(with_timeout 5 findfs "PARTUUID=${spec#PARTUUID=}" 2>/dev/null || true)" ;;
    PARTLABEL=*)
      local lbl="${spec#PARTLABEL=}"
      if [ -e "/dev/disk/by-partlabel/${lbl}" ]; then
        dev="$(readlink -f "/dev/disk/by-partlabel/${lbl}" 2>/dev/null || true)"
      else
        dev="$(with_timeout 5 findfs "PARTLABEL=${lbl}" 2>/dev/null || true)"
      fi ;;
    /dev/*)     dev="$spec" ;;
    *)          dev="/dev/$spec" ;;
  esac
  [ -n "$dev" ] || return 1
  # Canonicalise and verify it is a real block device under /dev
  dev="$(readlink -f "$dev" 2>/dev/null || true)"
  [ -n "$dev" ] || return 1
  case "$dev" in /dev/*) ;; *) return 1 ;; esac
  [ -b "$dev" ] || return 1
  printf '%s' "$dev"
}

# ─── resolve_dev with comma fallbacks ────────────────────────────────────────
resolve_dev() {
  local rest="$1" alt dev
  while [ -n "$rest" ]; do
    case "$rest" in
      *,*) alt="${rest%%,*}"; rest="${rest#*,}" ;;
      *)   alt="$rest";       rest="" ;;
    esac
    dev="$(resolve_one "$alt")"
    [ -n "$dev" ] && { printf '%s' "$dev"; return 0; }
  done
  return 1
}

# ─── wait_for_dev ────────────────────────────────────────────────────────────
wait_for_dev() {
  local spec="$1" timeout="$2" i=0 dev
  while [ "$i" -lt "$timeout" ]; do
    dev="$(resolve_dev "$spec")"
    [ -n "$dev" ] && { printf '%s' "$dev"; return 0; }
    sleep 1; i=$((i+1))
    [ $((i % 3)) -eq 0 ] && warn "still waiting for ${spec} (${i}/${timeout}s)..."
  done
  return 1
}

# ─── Safe mount helpers ──────────────────────────────────────────────────────
safe_mount() {
  local type="$1" src="$2" dst="$3" opts="${4:-}"
  mkdir -p "$dst" || emergency "cannot mkdir $dst"
  if [ -n "$opts" ]; then
    mount -t "$type" -o "$opts" "$src" "$dst" 2>/dev/null || return 1
  else
    mount -t "$type" "$src" "$dst" 2>/dev/null || return 1
  fi
  record_mount "$dst"
  return 0
}

# ─── Phase 3+4: locate and mount squashfs READ-ONLY ───────────────────────────
mount_squashfs() {
  # Strategy (a): media-spec:file-path
  case "$SQUASH_SPEC" in
    *:*)
      local mspec fpath dev
      mspec="${SQUASH_SPEC%%:*}"
      fpath="${SQUASH_SPEC#*:}"
      validate_devspec "$mspec"
      dev="$(wait_for_dev "$mspec" "$PROBE_TIMEOUT")" \
        || emergency "boot media '${mspec}' never appeared"
      log "mounting media ${dev}"
      safe_mount auto "$dev" "$MEDIA" "ro,nodev,nosuid,noexec" \
        || safe_mount iso9660 "$dev" "$MEDIA" "ro,nodev,nosuid,noexec" \
        || safe_mount vfat   "$dev" "$MEDIA" "ro,nodev,nosuid,noexec" \
        || emergency "cannot mount boot media ${dev}"
      [ -f "${MEDIA}/${fpath}" ] || emergency "squashfs file '${fpath}' not found on ${dev}"
      # Verify squashfs magic before mount
      local magic
      magic="$(dd if="${MEDIA}/${fpath}" bs=1 count=2 2>/dev/null | od -An -tx1 | tr -d ' ')"
      [ "$magic" = "6873" ] || warn "squashfs magic not detected on ${fpath} (got ${magic}); continuing anyway"
      log "loop-mounting squashfs ${MEDIA}/${fpath}"
      safe_mount squashfs "${MEDIA}/${fpath}" "$LOWER" "ro,loop,nodev,nosuid" \
        || emergency "squashfs mount failed (corrupt image or missing decompression support)"
      return 0
      ;;
  esac

  # Strategy (b): explicit block device that IS the squashfs
  if [ -n "$SQUASH_SPEC" ]; then
    local dev
    dev="$(wait_for_dev "$SQUASH_SPEC" "$PROBE_TIMEOUT")" \
      || emergency "squashfs device '${SQUASH_SPEC}' never appeared"
    log "loop-mounting squashfs block device ${dev}"
    safe_mount squashfs "$dev" "$LOWER" "ro,nodev,nosuid" \
      || safe_mount squashfs "$dev" "$LOWER" "ro,loop,nodev,nosuid" \
      || emergency "squashfs mount of ${dev} failed"
    return 0
  fi

  # Strategy (c): auto-scan removable media
  log "auto-scanning for /${SQUASH_DEFAULT_FILE} (label ${ROOT_LABEL} preferred)"
  local ordered_devs=""
  ordered_devs="$(with_timeout 5 findfs "LABEL=${ROOT_LABEL}" 2>/dev/null || true)"
  for d in /dev/sr* /dev/sd* /dev/nvme*n* /dev/vd* /dev/mmcblk*; do
    [ -b "$d" ] || continue
    case " $ordered_devs " in *" $d "*) ;; *) ordered_devs="$ordered_devs $d" ;; esac
  done

  local i=0
  while [ "$i" -lt "$PROBE_TIMEOUT" ]; do
    for d in $ordered_devs; do
      [ -b "$d" ] || continue
      umount "$MEDIA" 2>/dev/null || true
      if safe_mount auto "$d" "$MEDIA" "ro,nodev,nosuid,noexec" \
         || safe_mount iso9660 "$d" "$MEDIA" "ro,nodev,nosuid,noexec" \
         || safe_mount vfat "$d" "$MEDIA" "ro,nodev,nosuid,noexec"; then
        if [ -f "${MEDIA}/${SQUASH_DEFAULT_FILE}" ]; then
          log "found squashfs on ${d}"
          if safe_mount squashfs "${MEDIA}/${SQUASH_DEFAULT_FILE}" "$LOWER" "ro,loop,nodev,nosuid"; then
            return 0
          fi
          warn "squashfs on ${d} failed to mount; continuing scan"
        fi
        umount "$MEDIA" 2>/dev/null || true
      fi
    done
    sleep 1; i=$((i+1))
  done
  emergency "no bootable squashfs found after ${PROBE_TIMEOUT}s"
}
mount_squashfs

# ─── Phase 5: writable upper layer ───────────────────────────────────────────
setup_upper() {
  local dev=""
  if [ -n "$PERSIST_SPEC" ]; then
    dev="$(wait_for_dev "$PERSIST_SPEC" "$PROBE_TIMEOUT")" \
      || { warn "persist device '${PERSIST_SPEC}' not found — falling back to tmpfs"; PERSIST_SPEC=""; }
  fi
  if [ -n "$PERSIST_SPEC" ]; then
    log "mounting PERSISTENT upper ${dev} (ext4)"
    if safe_mount ext4 "$dev" "$UPPER_BASE" "nodev,nosuid"; then
      : # ok
    else
      warn "ext4 mount of ${dev} failed — falling back to ephemeral tmpfs"
      PERSIST_SPEC=""
    fi
  fi
  if [ -z "$PERSIST_SPEC" ]; then
    log "mounting EPHEMERAL upper (tmpfs, size=${UPPER_SIZE})"
    safe_mount tmpfs tmpfs "$UPPER_BASE" "size=${UPPER_SIZE},mode=0755,nodev,nosuid" \
      || emergency "tmpfs upper mount failed"
  fi
  mkdir -p "${UPPER_BASE}/upper" "${UPPER_BASE}/work" \
    || emergency "cannot create overlay upper/work dirs"
}
setup_upper

# ─── Phase 6: overlay-mount final root ────────────────────────────────────────
log "composing overlay root"
safe_mount overlay overlay "$NEWROOT" "lowerdir=${LOWER},upperdir=${UPPER_BASE}/upper,workdir=${UPPER_BASE}/work" \
  || emergency "overlay mount failed (is CONFIG_OVERLAY_FS=y? are upper/work on a writable fs?)"

# Sanity: the new root must contain an init
NEWINIT=""
for cand in /sbin/init /init /bin/init /sbin/openrc-init; do
  if [ -x "${NEWROOT}${cand}" ]; then
    # Verify it's not a symlink escaping the root
    if [ -L "${NEWROOT}${cand}" ]; then
      local linktgt
      linktgt="$(readlink "${NEWROOT}${cand}")"
      case "$linktgt" in /*) : ;; *) NEWINIT="$cand"; break ;; esac
      warn "${cand} is an absolute symlink inside newroot; accepting but inspect manually"
    fi
    NEWINIT="$cand"; break
  fi
done
[ -n "$NEWINIT" ] || emergency "no executable init found inside squashfs root"
log "real init will be: ${NEWINIT}"

# ─── rd.break: developer escape hatch ──────────────────────────────────────────
if has_flag rd.break; then
  trap - EXIT
  warn "rd.break requested — root composed at ${NEWROOT} but NOT entered."
  warn "Type 'exit' to continue to switch_root."
  /bin/sh
fi

# ─── Phase 7: move pseudo-fs into newroot and switch_root ─────────────────────
log "relocating pseudo-filesystems into new root"
for fs in /proc /sys /dev /run; do
  mkdir -p "${NEWROOT}${fs}"
  mount --move "$fs" "${NEWROOT}${fs}" 2>/dev/null \
    || warn "could not move ${fs} (continuing)"
done

trap - EXIT

log "switch_root → ${NEWINIT}"
exec switch_root "$NEWROOT" "$NEWINIT" \
  || emergency "switch_root failed — ${NEWINIT} not executable or ${NEWROOT} not a mountpoint"

emergency "reached end of /init — exec switch_root did not take over (impossible)"
