# ════════════════════════════════════════════════════════════════════════════
#  AIOS — Hardened Kernel configuration fragment
#  Target: Linux 6.18.x (LTS), x86_64
#
#  HARDENING CHANGES
#  ─────────────────
#  • Memory safety: init-on-alloc/free, slab freelist hardening, vmap stack,
#    page-table checks, refcount integrity.
#  • W^X enforcement: STRICT_KERNEL_RWX, STRICT_MODULE_RWX, DEBUG_WX.
#  • Runtime integrity: kernel lockdown LSM (early), static usermodehelper,
#    fortify_source, stackprotector strong.
#  • Information leak reduction: dmesg restrict, no kcore, no legacy PTY.
#  • Module policy: signatures enabled (not forced, so =m still works) with
#    SHA-512; compression stays zstd.
#  • Fixed contradictions: CGROUPS comment vs value, serial console comment.
#  • Boot-critical path unchanged (all =y).
# ════════════════════════════════════════════════════════════════════════════

# ── Base architecture ───────────────────────────────────────────────────────
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_X86_X2APIC=y
CONFIG_NR_CPUS=64

# ── Compression (kernel image + squashfs decompressors) ──────────────────────
CONFIG_KERNEL_ZSTD=y
CONFIG_CRYPTO=y
CONFIG_DECOMPRESS_XZ=y
CONFIG_DECOMPRESS_ZSTD=y
CONFIG_DECOMPRESS_LZ4=y
CONFIG_DECOMPRESS_LZO=y
CONFIG_DECOMPRESS_GZIP=y

# ── squashfs (root filesystem) — all builtin ───────────────────────────────
CONFIG_MISC_FILESYSTEMS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_FILE_DIRECT=y
CONFIG_SQUASHFS_DECOMP_MULTI_PERCPU=y
CONFIG_SQUASHFS_XATTR=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_LZ4=y
CONFIG_SQUASHFS_LZO=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_SQUASHFS_4K_DEVBLK_SIZE=y

# ── overlayfs — builtin ──────────────────────────────────────────────────────
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_XINO_AUTO=y
CONFIG_OVERLAY_FS_METACOPY=y

# ── tmpfs (ephemeral upper layer) ────────────────────────────────────────────
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_SHMEM=y

# ── loop device — builtin ──────────────────────────────────────────────────
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_LOOP_MIN_COUNT=8

# ── Pseudo-filesystems ─────────────────────────────────────────────────────
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=yCONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS_MOUNTPOINT=y

# ── initramfs / initrd support ───────────────────────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y
CONFIG_RD_ZSTD=y
CONFIG_INITRAMFS_COMPRESSION_ZSTD=y

# ── Boot media drivers — builtin ─────────────────────────────────────────────
CONFIG_BLOCK=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_SR=y
CONFIG_CHR_DEV_SG=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_ATA_PIIX=y
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_SCSI=y

# ── Boot media filesystems — builtin ─────────────────────────────────────────
CONFIG_ISO9660_FS=y
CONFIG_JOLIET=y
CONFIG_ZISOFS=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_UTF8=y
CONFIG_NLS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y

# ── Partition tables ─────────────────────────────────────────────────────────
CONFIG_PARTITION_ADVANCED=y
CONFIG_MSDOS_PARTITION=y
CONFIG_EFI_PARTITION=y

# ── EFI ──────────────────────────────────────────────────────────────────────
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_MIXED=n
CONFIG_EFIVAR_FS=y
CONFIG_EFI_RUNTIME_MAP=y

# ── Console / framebuffer ────────────────────────────────────────────────────
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_DRM=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_I915=m
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_VIRTIO_GPU=y

# ── Input ────────────────────────────────────────────────────────────────────
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_EVDEV=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_TTY=y
# Serial console disabled for production kiosk (reduces attack surface);
# enable CONFIG_SERIAL_8250=y + CONFIG_SERIAL_8250_CONSOLE=y for headless debug.
CONFIG_SERIAL_8250=n
CONFIG_SERIAL_8250_CONSOLE=n

# ── Networking ───────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IPV6=n
CONFIG_PACKET_DIAG=n
CONFIG_NETDEVICES=y
# Hardware NICs left modular; only virtio-net builtin for QEMU test VM
CONFIG_ETHERNET=n
CONFIG_E1000=n
CONFIG_E1000E=n
CONFIG_R8169=n
CONFIG_IGB=n
CONFIG_VIRTIO_NET=y
CONFIG_WLAN=n
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_USB_NET_CDCETHER=m
CONFIG_USB_NET_CDC_NCM=m
CONFIG_USB_IPHETH=m

# ── Process / scheduling / ABI ───────────────────────────────────────────────
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_EVENTFD=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_POSIX_TIMERS=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT=y
CONFIG_NO_HZ_IDLE=y
# CGROUPS: enabled (cgroups v2 is init-agnostic and required by some sandboxes)
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# ── Memory management ──────────────────────────────────────────────────────
CONFIG_MMU=y
CONFIG_SWAP=n
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_KSM=y

# ── Security / integrity / hardening ───────────────────────────────────────
CONFIG_SECCOMP=y
CONFIG_SECURITY=y
CONFIG_SECURITY_DMESG_RESTRICT=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_FORTIFY_SOURCE=y

# Memory safety hardening
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SHUFFLE_ALLOCATOR=y
CONFIG_VMAP_STACK=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_DEBUG_WX=y
CONFIG_PAGE_TABLE_CHECK=y
CONFIG_PAGE_TABLE_CHECK_ENFORCED=y
CONFIG_REFCOUNT_FULL=y

# Kernel lockdown (integrity mode prevents direct access to kernel memory)
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_INTEGRITY=y

# Static usermodehelper path (prevents runtime hijacking of usermode helper)
CONFIG_STATIC_USERMODEHELPER=y
CONFIG_STATIC_USERMODEHELPER_PATH="/sbin/usermode-helper"

# Information leak reduction
CONFIG_PROC_KCORE=n
CONFIG_LEGACY_PTYS=n
CONFIG_BINFMT_MISC=n

# ── Entropy ────────────────────────────────────────────────────────────────
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_RANDOM_TRUST_CPU=y

# ── Module policy (signed but not forced, so out-of-tree =m still loads) ─
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA512=y
CONFIG_MODULE_SIG_FORCE=n
CONFIG_MODULE_COMPRESS_ZSTD=y

# ── Kernel surface trimming ──────────────────────────────────────────────────
CONFIG_KALLSYMS=y
CONFIG_DEBUG_INFO_NONE=y
CONFIG_PRINTK=y
CONFIG_BUG=y

# ── Explicitly OFF: AIOS does not use these ─────────────────────────────────
CONFIG_KEXEC=n
CONFIG_HIBERNATION=n
CONFIG_COMPAT_BRK=n
